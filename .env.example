# Claude Code Sandbox Configuration
# Copy this file to .env and customize as needed

# Project identifier (used for container naming and network isolation)
# Default: basename of the worktree directory
# PODMAN_PROJECT=dev-and-ai-tools

# Slot number for multi-worktree setups (allows parallel sandbox instances)
# Default: 0
# NEXUS_SLOT=0

# Container image name
# Default: localhost/claude-sandbox:latest
# CLAUDE_SANDBOX_IMAGE=localhost/claude-sandbox:latest

# Path to Containerfile (relative to repo root)
# Default: auto-detected from well-known locations
# CLAUDE_SANDBOX_CONTAINERFILE=containers/claude-sandbox/Containerfile

# Auth token storage directory
# Default: ~/.claude-sandbox/auth
# CLAUDE_SANDBOX_AUTH_DIR=~/.claude-sandbox/auth

# Resource limits
# CLAUDE_SANDBOX_MEMORY=4g
# CLAUDE_SANDBOX_CPUS=2
